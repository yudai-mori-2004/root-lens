# ===========================================
# RootLens Web — 環境変数
# ===========================================

# --- Supabase (クライアント: shortId解決) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (サーバー: ページ・コンテンツ書き込み) ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- DAS API (クライアント: cNFT検索・検証) ---
NEXT_PUBLIC_DAS_RPC_URL=https://devnet.helius-rpc.com/?api-key=xxx

# --- Solana RPC (サーバー: Title Protocol登録) ---
SOLANA_RPC_URL=https://api.devnet.solana.com

# --- Cloudflare R2 (サーバー: 画像アップロード) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BUCKET=rootlens-public
R2_PUBLIC_URL=

# --- Root CA (サーバー: デバイス証明書発行) ---
ROOT_CA_CERT_PEM=
ROOT_CA_KEY_PEM=

# --- Operator Wallet (サーバー: Title Protocol devnet登録) ---
OPERATOR_WALLET_JSON=
